# ============================================
# Opsight - AIOps 智能运维监控平台 环境配置
# ============================================
# 复制此文件为 .env 并根据实际环境修改参数
#   cp .env.example .env
# ============================================

# ============================================
# 一、服务端口配置
# ============================================
# 后端 API 服务监听端口（容器内部）
API_PORT=8800
# 前端 Next.js 服务监听端口（容器内部）
FRONTEND_PORT=3800
# Nginx HTTP 对外暴露端口
NGINX_HTTP_PORT=80
# Nginx HTTPS 对外暴露端口
NGINX_HTTPS_PORT=443

# ============================================
# 二、数据库配置（PostgreSQL）
# ============================================
# 数据库主机地址（容器内服务名，无需修改）
DB_HOST=postgres
# 数据库端口
DB_PORT=5432
# 数据库用户名
DB_USER=opsight
# 数据库密码（生产环境务必修改为强密码）
DB_PASSWORD=opsight_secret
# 数据库名称
DB_NAME=opsight

# ============================================
# 三、运行模式
# ============================================
# Gin 框架运行模式：debug（开发）/ release（生产）
# 生产环境必须设为 release，关闭调试信息输出
GIN_MODE=release

# ============================================
# 四、日志配置
# ============================================
# 日志级别：debug / info / warn / error
# debug 会输出详细的 SQL 语句和请求参数
LOG_LEVEL=info
# Nginx 访问日志保留天数
NGINX_LOG_RETENTION=30

# ============================================
# 五、安全配置
# ============================================

# --- 认证相关 ---
# JWT 签名密钥（生产环境必须修改为随机字符串）
# 生成方式: openssl rand -base64 32
JWT_SECRET=change-me-to-a-random-secret
# JWT Token 过期时间（小时）
JWT_EXPIRY_HOURS=24
# 会话超时时间（分钟），超时后需重新登录
SESSION_TIMEOUT_MINUTES=60

# --- Agent API 密钥 ---
# Agent 上报数据时使用的 API 密钥（Agents 使用 Bearer token 认证）
# 生成方式: openssl rand -base64 32
AGENT_API_KEY=change-me-to-a-random-agent-key

# --- 登录保护 ---
# 登录失败最大尝试次数（超过后账户锁定）
LOGIN_MAX_ATTEMPTS=5
# 账户锁定时间（分钟）
LOGIN_LOCK_MINUTES=15

# --- API 速率限制 ---
# 是否启用 API 速率限制
RATE_LIMIT_ENABLED=true
# 每秒允许的最大请求数（每个 IP）
RATE_LIMIT_RPS=100
# 速率限制突发容量
RATE_LIMIT_BURST=20

# --- CORS 跨域配置 ---
# 允许的跨域来源（多个用逗号分隔，留空则允许所有来源）
# 生产环境建议配置具体域名，如: https://opsight.example.com
CORS_ALLOWED_ORIGINS=

# --- 审计日志 ---
# 是否启用操作审计日志
AUDIT_ENABLED=true
# 审计日志保留天数（超过后自动清理）
AUDIT_RETENTION_DAYS=90

# ============================================
# 六、SSL/TLS 配置（生产环境部署时启用）
# ============================================
# SSL 证书路径（绝对路径或相对于项目根目录）
# 证书文件需包含完整的证书链
# SSL_CERT_PATH=./ssl/fullchain.pem
# SSL 私钥路径
# SSL_KEY_PATH=./ssl/privkey.pem
# 是否将 HTTP 请求自动重定向到 HTTPS
# ENABLE_HTTPS_REDIRECT=false

# ============================================
# 七、超时与传输限制
# ============================================
# API 代理读取超时（秒），影响长时间请求
API_PROXY_READ_TIMEOUT=60
# API 代理连接超时（秒）
API_PROXY_CONNECT_TIMEOUT=10
# API 代理发送超时（秒）
API_PROXY_SEND_TIMEOUT=60
# 客户端最大请求体大小（支持 K/M/G 单位）
CLIENT_MAX_BODY_SIZE=10m

# ============================================
# 八、数据持久化
# ============================================
# 数据库数据存储目录（可改为外部挂载路径或独立磁盘）
# DATA_DIR=./data

# ============================================
# 九、告警通知
# ============================================
# --- SMTP 邮件通知 ---
# SMTP 邮件服务器地址
SMTP_HOST=smtp.example.com
# SMTP 端口
SMTP_PORT=587
# SMTP 认证用户名
SMTP_USER=opsight@example.com
# SMTP 认证密码
SMTP_PASSWORD=
# SMTP 发件人邮箱
SMTP_FROM=opsight@example.com

# --- 企业微信通知 ---
# 企业微信机器人 Webhook URL
# 获取方式：企业微信管理后台 → 群机器人 → 添加机器人 → 复制 Webhook 地址
WECHAT_WEBHOOK_URL=
